# Azure APIM Configuration
AZURE_APIM_ENDPOINT=https://all-azure-openai-service-apimanagement.azure-api.net/<企業サブスクリプション識別子>
AZURE_APIM_SUBSCRIPTION_KEY=your-subscription-key-here
AZURE_API_VERSION=2025-04-01-preview
AZURE_DEPLOYMENT_NAME=gpt-5

# Client approach: "azure" (recommended) or "openai"
CLIENT_APPROACH=azure

# Web Fetch 設定（オプション）
WEB_FETCH_TIMEOUT=30
WEB_FETCH_MAX_SIZE=100000
